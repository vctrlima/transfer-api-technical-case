            "body": {
              "mode": "raw",
              "raw": "{\n  \"originAccountId\": \"acc-origin-001\",\n  \"destinationAccountId\": \"acc-dest-001\",\n  \"amount\": 100.00,\n  \"description\": \"Pagamento de serviço\"\n}",
